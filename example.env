API_KEY=
API_HOST=
OPEN_AI_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
EMAIL_USER=
EMAIL_PASSWORD=
SMTP_SERVER=
DEFAULT_FROM_EMAIL=
NOTIFICATION_EMAIL=info@jackhui.com.au
IG_ACCESS_TOKEN=
IG_USER_ID=
SKIP_IG_UPLOAD=true
SKIP_YT_UPLOAD=false
# YouTube Safety (added 2026-05-31)
# Privacy status for uploaded videos: private, unlisted, or public
# Default: private (videos uploaded privately for safety review)
YOUTUBE_DEFAULT_PRIVACY=private

# Compliance Gate Settings
# Set to true for stricter checks (warnings become errors)
COMPLIANCE_STRICT_MODE=false
# Set to true to require source manifest for all uploads
COMPLIANCE_REQUIRE_MANIFEST=false
# Path to custom blocklist file (optional)
COMPLIANCE_BLOCKLIST_FILE=
# Set to true to abort upload if compliance check fails
COMPLIANCE_ABORT_ON_FAIL=false

# Auto-Publish After Processing Check (added 2026-05-31)
# When enabled, after uploading as private, the pipeline will:
# 1. Wait for YouTube processing to complete
# 2. Check for processing failures, rejections, or errors
# 3. If clean, auto-publish to the target privacy status
# 4. If issues detected, keep private and send notification
#
# IMPORTANT LIMITATION: YouTube Data API does NOT expose Content ID claims.
# Auto-publish can only detect processing failures and rejections.
# Content ID claims may still appear after publishing.
# Enable only if you're comfortable with this limitation.
YOUTUBE_AUTO_PUBLISH_AFTER_CHECK=false
# Max time (minutes) to wait for processing before timing out
YOUTUBE_CHECK_WAIT_MINUTES=30
# Interval (seconds) between status checks
YOUTUBE_CHECK_INTERVAL_SECONDS=30
# If true, any rejection reason prevents auto-publish (recommended)
YOUTUBE_CLEAN_CHECK_REQUIRES_NO_REJECTION=true
# Target privacy status after successful check: public or unlisted
YOUTUBE_AUTO_PUBLISH_PRIVACY=public
